# ═══════════════════════════════════════════════════════════════════════════════
# SOMA .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Rust
# ─────────────────────────────────────────────────────────────────────────────
target/
# Note: Cargo.lock is tracked for reproducible builds

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
*.sql.bak
*.dump

# ─────────────────────────────────────────────────────────────────────────────
# IDE & Editors
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
nul

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code
# ─────────────────────────────────────────────────────────────────────────────
.claude/

# ─────────────────────────────────────────────────────────────────────────────
# Personal Health Data - NEVER commit
# ─────────────────────────────────────────────────────────────────────────────
# Apple Health exports
apple_health_export/
*.xml

# Garmin/fitness files
*.fit
*.gpx
*.tcx

# Data exports and analysis outputs
*.csv
*.pkl
*.pickle
*.parquet
data/
exports/
health_data/

# ─────────────────────────────────────────────────────────────────────────────
# Temporary & Generated Files
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
*.bak
temp_*.json
