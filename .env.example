# ═══════════════════════════════════════════════════════════════════════════════
# Soma Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this to .env and configure for your environment
#
# SECURITY NOTES:
# - NEVER commit .env files with real credentials to version control
# - Use strong, unique passwords in production
# - Generate API keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - Keep debug=false in production

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED in production (SOMA_DEBUG=false)
# In development (SOMA_DEBUG=true), defaults to local dev database

# Local development
SOMA_DATABASE_URL=postgresql://soma:CHANGE_ME_IN_PRODUCTION@localhost:5432/soma

# Docker development (uncomment when running API in Docker)
# SOMA_DATABASE_URL=postgresql://soma:CHANGE_ME_IN_PRODUCTION@timescaledb:5432/soma

# Database password (used by Docker Compose)
# Generate with: openssl rand -base64 32
SOMA_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (Caching & Job Queue)
# ─────────────────────────────────────────────────────────────────────────────
# Optional - caching is disabled if not configured

# Local development (no auth)
SOMA_REDIS_URL=redis://localhost:6379/0

# Production (with authentication)
# SOMA_REDIS_URL=redis://redis:6379/0
# SOMA_REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Cache TTL in seconds (default: 5 minutes)
SOMA_CACHE_TTL=300

# ─────────────────────────────────────────────────────────────────────────────
# API SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
SOMA_DEBUG=true
SOMA_LOG_LEVEL=INFO
SOMA_JSON_LOGS=false

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
# Options: disabled, api_key, jwt, oauth2
# SECURITY: Default is api_key. Only use 'disabled' for local development!
SOMA_AUTH_MODE=api_key

# API Key (required if AUTH_MODE=api_key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# WARNING: Change this in production! If not set, a random key is generated on startup.
SOMA_API_KEY=

# Allow API key in query string (NOT recommended - keys appear in logs/history)
SOMA_ALLOW_API_KEY_QUERY=false

# JWT settings (if AUTH_MODE=jwt)
# SOMA_JWT_SECRET=your-secret-key-here
# SOMA_JWT_ALGORITHM=HS256
# SOMA_JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
# Protection against abuse and DoS attacks

# Enable/disable rate limiting (default: true)
SOMA_RATE_LIMIT_ENABLED=true

# Default limit: requests per window for GET endpoints
SOMA_RATE_LIMIT_DEFAULT=100

# Window size in seconds
SOMA_RATE_LIMIT_WINDOW=60

# Stricter limit for write operations (POST/PUT/DELETE)
SOMA_RATE_LIMIT_WRITE=20

# Very strict limit for auth-related endpoints (prevent brute force)
SOMA_RATE_LIMIT_AUTH=5

# ─────────────────────────────────────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
SOMA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# RUST CORE (Ingestion Pipeline)
# ─────────────────────────────────────────────────────────────────────────────
RUST_LOG=soma_core=info

# ─────────────────────────────────────────────────────────────────────────────
# PGADMIN (Optional - Database Admin UI)
# ─────────────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@soma.local
PGADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ─────────────────────────────────────────────────────────────────────────────
# WHOOP INTEGRATION (OAuth2)
# ─────────────────────────────────────────────────────────────────────────────
# Register your app at https://developer.whoop.com to get credentials
# Required scopes: read:recovery, read:cycles, read:sleep, read:workout,
#                  read:profile, read:body_measurement

SOMA_WHOOP_CLIENT_ID=
SOMA_WHOOP_CLIENT_SECRET=
SOMA_WHOOP_REDIRECT_URI=http://localhost:8000/v1/oauth/callback/whoop
